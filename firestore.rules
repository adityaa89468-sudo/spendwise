
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && request.resource.data.email is string
                    && request.resource.data.createdAt == request.time;
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['monthlyBudget', 'currency', 'displayName']);
      
      // Transactions Subcollection
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.amount is number
                      && request.resource.data.type in ['income', 'expense']
                      && request.resource.data.category is string;
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'category', 'date', 'note']);
        allow delete: if isOwner(userId);
      }

      // Categories Subcollection
      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.type in ['income', 'expense'];
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
